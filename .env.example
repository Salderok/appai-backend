# Backend-specific env. Copy to backend/.env.
# Anything not set here falls back to repo-root .env, then process env.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

DEVICE_KEY=replace-with-a-long-random-string

DATABASE_URL=postgresql+asyncpg://appai:appai@localhost:5432/appai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=phi3:mini
# When true and a primary provider call fails, retry through Ollama.
ENABLE_OFFLINE_FALLBACK=false

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

WHISPER_PROVIDER=openai
TTS_PROVIDER=openai
TTS_VOICE=alloy

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

CORS_ORIGINS=http://localhost:8000,http://localhost:5173
